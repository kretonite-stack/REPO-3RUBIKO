---
/* TODO: reemplazar con historia/valores reales de la empresa */
const stats = [
  { value: "+10", label: "años de experiencia" },
  { value: "+50", label: "proyectos entregados" },
  { value: "100%", label: "cumplimiento de plazos" },
];
---

<section id="nosotros" class="border-y border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="mx-auto grid max-w-6xl gap-16 px-6 py-24 sm:px-10 lg:grid-cols-2">
    <div>
      <p class="reveal font-[var(--font-mono)] text-sm uppercase tracking-[0.2em] text-[var(--color-accent)]">
        Nosotros
      </p>
      <h2 class="reveal mt-3 font-[var(--font-display)] text-3xl font-semibold text-[var(--color-text)] sm:text-4xl">
        Precisión en cada etapa del proyecto
      </h2>
      <p class="reveal mt-6 text-[var(--color-text-muted)]">
        {/* TODO: texto real "quiénes somos" */}
        Un equipo técnico enfocado en resolver proyectos complejos con
        procesos claros, comunicación directa y estándares de calidad
        verificables en cada etapa.
      </p>
    </div>

    <div class="grid grid-cols-3 gap-6">
      {
        stats.map((stat) => (
          <div class="reveal rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-2)] p-6 text-center">
            <p class="font-[var(--font-display)] text-3xl font-semibold text-[var(--color-accent-strong)]">
              {stat.value}
            </p>
            <p class="mt-2 text-sm text-[var(--color-text-muted)]">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
