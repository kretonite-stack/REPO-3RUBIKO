---
/* TODO: reemplazar con los servicios reales una vez que Antigravity
   reporte el contenido encontrado en D:\3rubiko */
const services = [
  {
    name: "Diseño e ingeniería",
    description: "Planificación técnica y desarrollo de proyectos a medida.",
  },
  {
    name: "Ejecución de obra",
    description: "Construcción y montaje con control de calidad en cada etapa.",
  },
  {
    name: "Mantención",
    description: "Soporte técnico continuo posterior a la entrega del proyecto.",
  },
];
---

<section id="servicios" class="mx-auto max-w-6xl px-6 py-24 sm:px-10">
  <p class="reveal font-[var(--font-mono)] text-sm uppercase tracking-[0.2em] text-[var(--color-accent)]">
    Servicios
  </p>
  <h2 class="reveal mt-3 max-w-xl font-[var(--font-display)] text-3xl font-semibold text-[var(--color-text)] sm:text-4xl">
    Lo que hacemos
  </h2>

  <div class="mt-14 grid gap-6 sm:grid-cols-3">
    {
      services.map((service) => (
        <div class="reveal rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-8">
          <h3 class="font-[var(--font-display)] text-xl font-semibold text-[var(--color-text)]">
            {service.name}
          </h3>
          <p class="mt-3 text-[var(--color-text-muted)]">{service.description}</p>
        </div>
      ))
    }
  </div>
</section>
