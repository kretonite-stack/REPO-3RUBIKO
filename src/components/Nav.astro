<header id="main-header" class="fixed inset-x-0 top-0 z-50 transition-all duration-300 bg-transparent py-4">
  <!-- Gradiente sutil para asegurar lectura en el hero -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-transparent pointer-events-none -z-10"></div>
  
  <nav class="mx-auto flex max-w-[1440px] items-center justify-between px-6 sm:px-10 min-h-[66px] md:min-h-[78px]">
    
    <a href="/" class="brand" aria-label="3Kubiko — Inicio">
      <img
        src="https://res.cloudinary.com/ddqx435i5/image/upload/v1782952665/logo_f6sphu.png"
        alt="3Kubiko — Diseño y Construcción"
        class="brand__logo"
        width="570"
        height="190"
        fetchpriority="high"
        decoding="async"
      />
    </a>
    
    <ul class="hidden gap-10 text-[15px] font-medium text-white/80 sm:flex ml-auto mr-10">
      <li><a href="#nosotros" class="transition-colors hover:text-[var(--color-accent)]">Nosotros</a></li>
      <li><a href="#servicios" class="transition-colors hover:text-[var(--color-accent)]">Servicios</a></li>
      <li><a href="#proyectos" class="transition-colors hover:text-[var(--color-accent)]">Proyectos</a></li>
      <li><a href="#proceso" class="transition-colors hover:text-[var(--color-accent)]">Proceso</a></li>
      <li><a href="#contacto" class="transition-colors hover:text-[var(--color-accent)]">Contacto</a></li>
    </ul>
    
    <a
      href="#contacto"
      class="hidden sm:inline-block rounded-full border border-white/20 bg-white/5 backdrop-blur-md px-6 py-2.5 text-sm font-semibold text-white transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-black"
    >
      Cotizar proyecto
    </a>
  </nav>
</header>

<style>
.brand {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  text-decoration: none;
  line-height: 0;
}

.brand__logo {
  display: block;
  width: clamp(145px, 14vw, 190px);
  height: auto;
  max-height: 58px;
  object-fit: contain;
  object-position: left center;
  background: transparent;
  border: 0;
  box-shadow: none;
}

@media (max-width: 768px) {
  .brand__logo {
    width: 145px;
    max-height: 44px;
  }
}
</style>

<script>
  // Script para añadir efecto Glassmorphism al hacer scroll
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-[#111111]/85', 'backdrop-blur-md', 'border-b', 'border-white/10', 'shadow-lg');
      header?.classList.remove('bg-transparent', 'py-4');
      header?.classList.add('py-2');
    } else {
      header?.classList.remove('bg-[#111111]/85', 'backdrop-blur-md', 'border-b', 'border-white/10', 'shadow-lg', 'py-2');
      header?.classList.add('bg-transparent', 'py-4');
    }
  });
</script>
