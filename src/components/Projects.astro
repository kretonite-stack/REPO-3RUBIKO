---
/*
  Sección "Proyectos" — fase 4 del arco (Oscuro, patrón topográfico).
  Fondo: 03_backgrounds/bg_projects_topographic.png (mobile: ..._mobile.png)
*/
import { ThreeDPhotoCarousel } from './ui/3d-carousel';
---

<section
  id="proyectos"
  class="relative overflow-hidden bg-[var(--color-carbon)]"
  style="background-image: url('/backgrounds/bg_projects_topographic.png'); background-size: cover; background-position: center;"
>
  <div class="mx-auto w-full px-0 py-24 sm:px-0">
    <div class="mx-auto max-w-6xl px-6 sm:px-10">
      <p class="reveal font-[var(--font-mono)] text-sm uppercase tracking-[0.2em] text-[var(--color-accent)]">
        Proyectos Destacados
      </p>
      <h2 class="reveal mt-3 max-w-xl font-[var(--font-display)] text-3xl font-semibold text-[var(--color-text)] sm:text-4xl">
        Lo que hemos construido
      </h2>
    </div>

    <!-- Carrusel Interactivo 3D -->
    <div class="reveal mt-8 w-full">
      <ThreeDPhotoCarousel client:visible />
    </div>
  </div>
</section>
