<section
  id="contacto"
  class="relative overflow-hidden bg-[var(--color-sunrise)]"
  style="/* TODO: background-image: url('/backgrounds/bg_cta_sunrise.jpg'); background-size: cover; */"
>
<div class="mx-auto max-w-6xl px-6 py-24 sm:px-10">
  <div class="grid gap-16 lg:grid-cols-2">
    <div>
      <p class="reveal font-[var(--font-mono)] text-sm uppercase tracking-[0.2em] text-[#3a2410]">
        Contacto
      </p>
      <h2 class="reveal mt-3 font-[var(--font-display)] text-3xl font-semibold text-[#1a1006] sm:text-4xl">
        Conversemos tu proyecto
      </h2>
      <p class="reveal mt-6 max-w-md text-[#3a2410]">
        Cuéntanos qué necesitas y te contactamos a la brevedad.
      </p>
    </div>

    <form id="contact-form" class="reveal space-y-5">
      <div>
        <label for="name" class="mb-2 block text-sm text-[#3a2410]">Nombre</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="w-full rounded-[var(--radius-sm)] border border-black/15 bg-white/70 px-4 py-3 text-[#1a1006] outline-none backdrop-blur-sm focus-visible:border-[#1a1006]"
        />
      </div>
      <div>
        <label for="email" class="mb-2 block text-sm text-[#3a2410]">Correo</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full rounded-[var(--radius-sm)] border border-black/15 bg-white/70 px-4 py-3 text-[#1a1006] outline-none backdrop-blur-sm focus-visible:border-[#1a1006]"
        />
      </div>
      <div>
        <label for="message" class="mb-2 block text-sm text-[#3a2410]">Mensaje</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="w-full rounded-[var(--radius-sm)] border border-black/15 bg-white/70 px-4 py-3 text-[#1a1006] outline-none backdrop-blur-sm focus-visible:border-[#1a1006]"
        ></textarea>
      </div>

      <button type="submit" class="w-full rounded-[var(--radius-sm)] bg-[#1a1006] px-6 py-3 font-medium text-white transition-opacity hover:opacity-90 disabled:opacity-50">
        Enviar mensaje
      </button>

      <p id="form-status" role="status" class="text-sm text-[#3a2410]"></p>
    </form>
  </div>
</div>
</section>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.querySelector<HTMLFormElement>("#contact-form");
  const status = document.querySelector<HTMLParagraphElement>("#form-status");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form || !status) return;

    const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const formData = new FormData(form);

    submitButton && (submitButton.disabled = true);
    status.textContent = "Enviando…";

    const { error } = await supabase.from("contact_messages").insert({
      name: formData.get("name"),
      email: formData.get("email"),
      message: formData.get("message"),
    });

    if (error) {
      status.textContent =
        "No pudimos enviar tu mensaje. Inténtalo nuevamente o escríbenos directo por correo.";
    } else {
      status.textContent = "Gracias, recibimos tu mensaje. Te contactaremos pronto.";
      form.reset();
    }

    submitButton && (submitButton.disabled = false);
  });
</script>
