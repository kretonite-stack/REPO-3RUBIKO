<section id="contacto" class="mx-auto max-w-6xl px-6 py-24 sm:px-10">
  <div class="grid gap-16 lg:grid-cols-2">
    <div>
      <p class="reveal font-[var(--font-mono)] text-sm uppercase tracking-[0.2em] text-[var(--color-accent)]">
        Contacto
      </p>
      <h2 class="reveal mt-3 font-[var(--font-display)] text-3xl font-semibold text-[var(--color-text)] sm:text-4xl">
        Conversemos tu proyecto
      </h2>
      <p class="reveal mt-6 max-w-md text-[var(--color-text-muted)]">
        Cuéntanos qué necesitas y te contactamos a la brevedad.
      </p>
    </div>

    <form id="contact-form" class="reveal space-y-5">
      <div>
        <label for="name" class="mb-2 block text-sm text-[var(--color-text-muted)]">Nombre</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="w-full rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none focus-visible:border-[var(--color-accent-strong)]"
        />
      </div>
      <div>
        <label for="email" class="mb-2 block text-sm text-[var(--color-text-muted)]">Correo</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none focus-visible:border-[var(--color-accent-strong)]"
        />
      </div>
      <div>
        <label for="message" class="mb-2 block text-sm text-[var(--color-text-muted)]">Mensaje</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="w-full rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none focus-visible:border-[var(--color-accent-strong)]"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full rounded-[var(--radius-sm)] bg-[var(--color-accent)] px-6 py-3 font-medium text-[var(--color-ink)] transition-colors hover:bg-[var(--color-accent-strong)] disabled:opacity-50"
      >
        Enviar mensaje
      </button>

      <p id="form-status" role="status" class="text-sm text-[var(--color-text-muted)]"></p>
    </form>
  </div>
</section>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.querySelector<HTMLFormElement>("#contact-form");
  const status = document.querySelector<HTMLParagraphElement>("#form-status");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form || !status) return;

    const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const formData = new FormData(form);

    submitButton && (submitButton.disabled = true);
    status.textContent = "Enviando…";

    const { error } = await supabase.from("contact_messages").insert({
      name: formData.get("name"),
      email: formData.get("email"),
      message: formData.get("message"),
    });

    if (error) {
      status.textContent =
        "No pudimos enviar tu mensaje. Inténtalo nuevamente o escríbenos directo por correo.";
    } else {
      status.textContent = "Gracias, recibimos tu mensaje. Te contactaremos pronto.";
      form.reset();
    }

    submitButton && (submitButton.disabled = false);
  });
</script>
