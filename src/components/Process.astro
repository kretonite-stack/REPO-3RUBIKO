---
/*
  Sección "Proceso" — fase 5 del arco (Twilight, glass cards).
  Fondo: 03_backgrounds/bg_glass_twilight.png
  Íconos: diagnostico.svg, presupuesto.svg, ejecucion.svg, entrega.svg
  PENDIENTE: subir fondo e íconos reales a public/.
*/
const steps = [
  { name: "Diagnóstico", description: "Levantamos el contexto y los requerimientos del proyecto.", icon: "diagnostico" },
  { name: "Presupuesto", description: "Propuesta técnica y económica clara, sin letra chica.", icon: "presupuesto" },
  { name: "Ejecución", description: "Construcción con seguimiento y control de calidad continuo.", icon: "ejecucion" },
  { name: "Entrega", description: "Cierre formal del proyecto y acompañamiento posterior.", icon: "entrega" },
];
---

<section
  id="proceso"
  class="relative overflow-hidden bg-[var(--color-twilight)]"
  style="/* TODO: background-image: url('/backgrounds/bg_glass_twilight.png'); background-size: cover; */"
>
  <div class="mx-auto max-w-6xl px-6 py-24 sm:px-10">
    <p class="reveal font-[var(--font-mono)] text-sm uppercase tracking-[0.2em] text-[var(--color-dawn-lilac)]">
      Proceso
    </p>
    <h2 class="reveal mt-3 max-w-xl font-[var(--font-display)] text-3xl font-semibold text-white sm:text-4xl">
      Cómo trabajamos
    </h2>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((step, i) => (
          <div class="reveal card-glass p-6">
            <p class="font-[var(--font-mono)] text-xs text-white/60">0{i + 1}</p>
            {/* TODO: reemplazar por <Icon name={step.icon} /> cuando estén los SVG de 05_icons */}
            <div class="mt-3 h-8 w-8 rounded-full border border-white/40" aria-hidden="true" />
            <h3 class="mt-4 font-[var(--font-display)] text-lg font-semibold text-white">
              {step.name}
            </h3>
            <p class="mt-2 text-sm text-white/70">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
