---
/*
  Hero con video de fondo.
  La URL del video vive en la variable de entorno PUBLIC_HERO_VIDEO_URL
  (ver .env.example) — así no queda hardcodeada en el componente y se
  puede cambiar sin tocar código ni volver a desplegar componentes.

  TODO: reemplazar PUBLIC_HERO_VIDEO_URL en .env por la URL directa de
  Cloudinary (res.cloudinary.com/.../video/upload/....mp4), obtenida
  desde https://collection.cloudinary.com/ddqx435i5/94ae786043a1f0d106de0ba94389d0ab
*/
const videoUrl = import.meta.env.PUBLIC_HERO_VIDEO_URL || "";
const posterUrl = import.meta.env.PUBLIC_HERO_POSTER_URL || "/hero-poster.jpg";
---

<section
  class="relative flex min-h-[92vh] w-full items-end overflow-hidden bg-[var(--color-ink)]"
  aria-label="Presentación principal"
>
  {
    videoUrl ? (
      <video
        class="absolute inset-0 h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={posterUrl}
      >
        <source src={videoUrl} type="video/mp4" />
      </video>
    ) : (
      <div
        class="absolute inset-0 h-full w-full bg-cover bg-center"
        style={`background-image: url(${posterUrl})`}
      />
    )
  }

  {/* Velo de contraste para que el texto sea legible sobre el video */}
  <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-ink)] via-[var(--color-ink)]/40 to-[var(--color-ink)]/10" />

  <div class="relative z-10 mx-auto w-full max-w-6xl px-6 pb-20 pt-40 sm:px-10">
    <p class="reveal font-[var(--font-mono)] text-sm uppercase tracking-[0.2em] text-[var(--color-accent-strong)]">
      3Rubiko
    </p>
    <h1 class="reveal mt-4 max-w-3xl font-[var(--font-display)] text-4xl font-semibold leading-[1.05] text-[var(--color-text)] sm:text-6xl">
      {/* TODO: título real — pendiente de contenido/branding en D:\3rubiko */}
      Ingeniería y construcción con precisión de cada pieza
    </h1>
    <p class="reveal mt-6 max-w-xl text-lg text-[var(--color-text-muted)]">
      {/* TODO: subtítulo real */}
      Proyectos ejecutados con estándares técnicos exigentes, de principio a
      fin.
    </p>

    <div class="reveal mt-10 flex flex-wrap gap-4">
      <a
        href="#contacto"
        class="rounded-[var(--radius-sm)] bg-[var(--color-accent)] px-6 py-3 font-medium text-[var(--color-ink)] transition-colors hover:bg-[var(--color-accent-strong)]"
      >
        Conversemos tu proyecto
      </a>
      <a
        href="#servicios"
        class="rounded-[var(--radius-sm)] border border-[var(--color-border)] px-6 py-3 font-medium text-[var(--color-text)] transition-colors hover:border-[var(--color-accent-strong)]"
      >
        Ver servicios
      </a>
    </div>
  </div>
</section>
