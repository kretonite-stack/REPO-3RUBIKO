---
/*
  Hero con video de fondo.
  La URL del video vive en la variable de entorno PUBLIC_HERO_VIDEO_URL
  (ver .env.example) — así no queda hardcodeada en el componente y se
  puede cambiar sin tocar código ni volver a desplegar componentes.

  Zona segura: según la referencia de diseño, el sujeto del video (la
  construcción) queda hacia el centro-derecha del encuadre, así que todo
  el texto y los CTAs se mantienen en el tercio izquierdo, sobre un
  degradado horizontal (oscuro a la izquierda → transparente a la
  derecha) en vez del degradado inferior genérico.
*/
const videoUrl = import.meta.env.PUBLIC_HERO_VIDEO_URL || "";
const posterUrl = import.meta.env.PUBLIC_HERO_POSTER_URL || "/hero-poster.jpg";
---

<section
  class="relative flex min-h-[92vh] w-full items-center overflow-hidden bg-[var(--color-ink)]"
  aria-label="Presentación principal"
>
  {
    videoUrl ? (
      <video
        class="absolute inset-0 h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={posterUrl}
      >
        <source src={videoUrl} type="video/mp4" />
      </video>
    ) : (
      <div
        class="absolute inset-0 h-full w-full bg-cover bg-center"
        style={`background-image: url(${posterUrl})`}
      />
    )
  }

  {/* Velo de contraste: fuerte en el tercio izquierdo (zona de texto),
      se disuelve hacia el centro-derecha para no tapar el video */}
  <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-ink)] via-[var(--color-ink)]/75 to-transparent sm:via-[var(--color-ink)]/60" />
  {/* Vignette inferior sutil, ayuda a la legibilidad en pantallas bajas */}
  <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-ink)]/50 via-transparent to-transparent" />

  <div class="relative z-10 mx-auto w-full max-w-6xl px-6 pt-24 sm:px-10">
    <div class="max-w-md sm:max-w-lg">
      <p class="reveal font-[var(--font-mono)] text-sm uppercase tracking-[0.2em] text-[var(--color-accent-strong)]">
        3Rubiko
      </p>
      <h1 class="reveal mt-4 font-[var(--font-display)] text-4xl font-semibold leading-[1.05] text-[var(--color-text)] sm:text-5xl">
        Diseño y construcción integral, a tu medida.
      </h1>
      <p class="reveal mt-6 text-lg text-[var(--color-text-muted)]">
        {/* TODO: subtítulo definitivo — pendiente contenido real de D:\3rubiko */}
        Proyectos residenciales y comerciales ejecutados con precisión, de la
        idea a la entrega.
      </p>

      <div class="reveal mt-10 flex flex-wrap gap-4">
        <a
          href="#contacto"
          class="rounded-[var(--radius-sm)] bg-[var(--color-accent)] px-6 py-3 font-medium text-[var(--color-ink)] transition-colors hover:bg-[var(--color-accent-strong)]"
        >
          Conversemos tu proyecto
        </a>
        <a
          href="#servicios"
          class="rounded-[var(--radius-sm)] border border-[var(--color-border)] px-6 py-3 font-medium text-[var(--color-text)] transition-colors hover:border-[var(--color-accent-strong)]"
        >
          Ver servicios
        </a>
      </div>
    </div>
  </div>
</section>

