# Copia este archivo a .env y completa con tus valores reales.
# .env NUNCA se sube al repo (ya está en .gitignore).

# Supabase — Project Settings → API
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Hero — video de fondo
# URL directa de Cloudinary, formato:
# https://res.cloudinary.com/<cloud_name>/video/upload/<version>/<public_id>.mp4
PUBLIC_HERO_VIDEO_URL=
# Imagen de respaldo mientras carga el video / si el navegador no lo soporta
PUBLIC_HERO_POSTER_URL=/hero-poster.jpg
